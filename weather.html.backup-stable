<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SailDesk — Weather</title>
    <script src="/config.js"></script>
    <script src="https://api.mapbox.com/mapbox-gl-js/v3.4.0/mapbox-gl.js"></script>
    <link href="https://api.mapbox.com/mapbox-gl-js/v3.4.0/mapbox-gl.css" rel="stylesheet" />
    <link rel="icon" href="data:,">
    <style>
        :root {
            --navy:    #1B3A5C;
            --accent:  #2563EB;
            --font:    system-ui, -apple-system, "Segoe UI", Inter, sans-serif;
            --header:  48px;
            --timebar: 46px;
            --drawer-h: 380px;
            --bg:      #f8fafc;
            --surface: #ffffff;
            --border:  #e2e8f0;
            --muted:   #64748b;
        }
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body, html { width: 100%; height: 100%; overflow: hidden; font-family: var(--font); background: #1e293b; }

        /* ── Header ── */
        .sd-header {
            display: flex; align-items: center; gap: 1rem;
            background: var(--navy); padding: 0 1.5rem; height: var(--header);
            flex-shrink: 0; z-index: 100; position: relative;
        }
        .sd-logo { font-size: 1.1rem; font-weight: 800; color: #fff; letter-spacing: -.03em; }
        .sd-logo span { color: #60A5FA; }
        .sd-tab-bar { display: flex; gap: .25rem; }
        .sd-tab {
            border: none; background: none; color: rgba(255,255,255,.65);
            padding: .35rem .9rem; border-radius: 6px; font-size: .8rem;
            font-weight: 600; cursor: pointer; font-family: var(--font);
            transition: background .15s, color .15s; text-decoration: none; display: inline-flex; align-items: center;
        }
        .sd-tab:hover { background: rgba(255,255,255,.1); color: #fff; }
        .sd-tab.active { background: var(--accent); color: #fff; }
        .sd-header-time { margin-left: auto; font-size: .7rem; color: rgba(255,255,255,.5); white-space: nowrap; }

        /* ── Layout shell ── */
        #app { position: absolute; top: var(--header); left: 0; right: 0; bottom: 0; display: flex; flex-direction: column; }

        /* ── Map ── */
        #map-container {
            flex: 1; position: relative; overflow: hidden;
            transition: flex .3s ease;
        }
        #map { width: 100%; height: 100%; }
        #particle-canvas { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 2; }

        /* ── Loading indicator ── */
        #loading-indicator {
            position: absolute; top: 10px; left: 10px; z-index: 13;
            background: rgba(15,23,42,.88); color: #e2e8f0; padding: 8px 14px;
            font-family: monospace; border-radius: 6px; pointer-events: none;
            font-size: 12px; box-shadow: 0 4px 20px rgba(0,0,0,.2);
        }

        /* ── Pin marker ── */
        .sd-pin {
            width: 18px; height: 18px; border-radius: 50%;
            background: rgba(37,99,235,0.25);
            border: 2.5px solid #2563EB;
            box-shadow: 0 0 0 2px rgba(255,255,255,0.85), 0 2px 10px rgba(0,0,0,.5);
            cursor: crosshair;
        }
        .sd-pin:active { cursor: crosshair; }

        /* ── Pin popup (Windy-style) ── */
        #pin-popup {
            position: absolute; display: none; z-index: 20;
            background: #1e293b; color: #f1f5f9;
            border-radius: 10px; padding: 7px 14px 8px;
            font-family: var(--font); white-space: nowrap;
            box-shadow: 0 6px 20px rgba(0,0,0,.5);
            pointer-events: none;
            transform: translate(-50%, calc(-100% - 18px));
        }
        #pin-popup::after {
            content: ''; position: absolute; bottom: -8px; left: 50%;
            transform: translateX(-50%);
            border: 8px solid transparent;
            border-bottom: none;
            border-top-color: #1e293b;
        }
        .pp-label { font-size: .6rem; color: #64748b; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; margin-bottom: 2px; }
        .pp-reading { display: flex; align-items: center; gap: 6px; }
        .pp-speed { font-size: 1.25rem; font-weight: 800; }
        .pp-unit { font-size: .7rem; color: #94a3b8; font-weight: 600; margin-left: -3px; }
        .pp-arrow { font-size: 1rem; display: inline-block; }
        .pp-dir { font-size: .85rem; color: #94a3b8; font-weight: 600; }
        #pin-coords {
            position: absolute; bottom: 8px; left: 10px; z-index: 10;
            background: rgba(15,23,42,.75); color: #e2e8f0;
            font-size: 11px; font-family: monospace; padding: 4px 10px;
            border-radius: 4px; pointer-events: none; letter-spacing: .02em;
        }

        /* ── Map model pill box ── */
        #model-pill-box {
            position: absolute; top: 10px; right: 10px; z-index: 12;
            background: rgba(27,58,92,.96); backdrop-filter: blur(8px);
            padding: 8px; border-radius: 12px;
            display: flex; flex-direction: column; gap: 6px;
            border: 1px solid rgba(255,255,255,.15); box-shadow: 0 10px 30px rgba(0,0,0,.3);
        }
        #source-toggle-zone { display: flex; background: rgba(0,0,0,.25); padding: 2px; border-radius: 6px; margin-bottom: 2px; }
        .source-btn {
            flex: 1; background: transparent; border: none; color: #94a3b8; padding: 5px 0;
            font-size: 10px; font-weight: 800; text-transform: uppercase; border-radius: 4px;
            cursor: pointer; text-align: center; transition: all .1s;
        }
        .source-btn.active { background: #3b82f6; color: #fff; }
        .model-pill {
            background: transparent; border: none; color: #94a3b8; padding: 7px 14px;
            font-size: 11px; font-weight: 700; text-transform: uppercase; border-radius: 6px;
            cursor: pointer; text-align: left; transition: all .15s; min-width: 150px;
            display: flex; justify-content: space-between; align-items: center; gap: 6px;
        }
        .model-pill:hover { background: rgba(255,255,255,.05); color: #f1f5f9; }
        .model-pill.active { background: #e2e8f0; color: #0f172a; }
        .model-res-tag { font-size: 9px; opacity: .8; font-family: monospace; font-weight: 800; }
        .grib-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; display: none; }
        .grib-dot.green { background: #22c55e; box-shadow: 0 0 5px rgba(34,197,94,.6); }
        .grib-dot.red   { background: #ef4444; box-shadow: 0 0 5px rgba(239,68,68,.6); }
        .model-pill .grib-missing-label { font-size: 9px; color: #f87171; font-weight: 700; display: none; margin-left: auto; text-transform: uppercase; letter-spacing: .03em; }

        /* ── Time bar ── */
        #time-bar {
            height: var(--timebar); background: var(--navy); display: flex; align-items: center;
            gap: 12px; padding: 0 14px; flex-shrink: 0; border-top: 1px solid rgba(255,255,255,.12);
            z-index: 20; position: relative; overflow: visible;
        }
        #play-btn {
            width: 28px; height: 28px; border-radius: 50%; background: rgba(255,255,255,.15); border: none;
            color: #fff; font-size: 12px; cursor: pointer; display: flex; align-items: center;
            justify-content: center; flex-shrink: 0; transition: background .15s;
        }
        #play-btn:hover { background: rgba(255,255,255,.25); }
        #time-label {
            font-size: 11px; font-family: monospace; color: rgba(255,255,255,.6); white-space: nowrap;
            min-width: 130px; flex-shrink: 0;
        }
        #time-label strong { color: #fff; }
        #slider-wrap { flex: 1; display: flex; flex-direction: column; }
        #time-slider {
            width: 100%; -webkit-appearance: none; appearance: none;
            height: 6px; border-radius: 3px; outline: none; cursor: pointer;
            background: #334155;
        }
        #time-slider::-webkit-slider-thumb {
            -webkit-appearance: none; width: 16px; height: 16px; border-radius: 50%;
            background: #fff; box-shadow: 0 0 6px rgba(0,0,0,.5); cursor: pointer;
            border: 2px solid #0f172a;
        }
        #time-axis { position: relative; height: 18px; margin-top: 2px; }
        #time-axis .ta-tick {
            position: absolute; transform: translateX(-50%);
            font-size: 8.5px; color: rgba(255,255,255,.4); font-family: monospace;
            white-space: nowrap; line-height: 1;
        }
        #time-axis .ta-tick.ta-day {
            color: rgba(255,255,255,.85); font-weight: 700;
        }
        #time-axis .ta-tick::before {
            content: ''; display: block; width: 1px; height: 4px;
            background: rgba(255,255,255,.25); margin: 0 auto 1px;
        }

        /* ── Wind scale bar ── */
        #wind-scale {
            background: var(--navy); flex-shrink: 0; padding: 4px 14px 5px 56px;
            border-top: 1px solid rgba(255,255,255,.08);
        }
        #wind-scale-bar {
            height: 10px; border-radius: 3px;
            background: linear-gradient(to right,
                #cceeff 0%, #88ddff 6%, #44dd88 12%, #88ee44 18%, #ccee00 24%,
                #ffcc00 30%, #ff8000 36%, #ff4400 44%, #ff1100 52%,
                #f04080 62%, #cc44cc 74%, #8822bb 86%, #7700bb 100%);
        }
        #wind-scale-labels {
            display: flex; justify-content: space-between; margin-top: 2px;
        }
        #wind-scale-labels span { font-size: 8.5px; color: rgba(255,255,255,.55); font-family: monospace; }

        /* ── Comparison drawer ── */
        #comparison-drawer {
            background: var(--surface); border-top: 1px solid var(--border);
            flex-shrink: 0; overflow: hidden;
            max-height: 0; transition: max-height .3s ease;
            display: flex; flex-direction: column; z-index: 15;
        }
        #comparison-drawer.open { max-height: var(--drawer-h); }

        #drawer-toolbar {
            display: flex; align-items: center; gap: .6rem; padding: .45rem .75rem;
            border-bottom: 1px solid var(--border); background: var(--bg); flex-shrink: 0;
        }
        #drawer-toggle {
            width: 22px; height: 22px; border: 1px solid var(--border); border-radius: 5px;
            background: var(--surface); cursor: pointer; display: flex; align-items: center;
            justify-content: center; font-size: 10px; color: var(--muted); flex-shrink: 0;
            transition: background .15s;
        }
        #drawer-toggle:hover { background: var(--border); }

        .tb-label { font-size: .68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: var(--muted); }

        /* Hours toggle */
        .tb-hours { display: flex; background: #e2e8f0; border-radius: 5px; padding: 2px; gap: 2px; }
        .tb-hr-btn {
            border: none; background: transparent; color: var(--muted); padding: .18rem .55rem;
            font-size: .7rem; font-weight: 700; border-radius: 4px; cursor: pointer; font-family: var(--font);
        }
        .tb-hr-btn.active { background: var(--accent); color: #fff; }

        /* Metric tabs — same style as hours */
        .tb-metric { display: flex; background: #e2e8f0; border-radius: 5px; padding: 2px; gap: 2px; }
        .tb-metric-btn {
            border: none; background: transparent; color: var(--muted); padding: .18rem .6rem;
            font-size: .7rem; font-weight: 700; border-radius: 4px; cursor: pointer; font-family: var(--font);
        }
        .tb-metric-btn.active { background: var(--accent); color: #fff; }

        /* Model picker separator */
        .tbl-panel-sep {
            font-size: .6rem; color: #94a3b8; text-align: center;
            padding: .3rem .5rem .1rem; letter-spacing: .05em; text-transform: uppercase;
        }

        /* Model picker */
        #tbl-models-btn {
            border: none; background: var(--accent); color: #fff;
            padding: .2rem .65rem; border-radius: 5px; font-size: .72rem; font-weight: 700;
            cursor: pointer; display: flex; align-items: center; gap: .3rem; font-family: var(--font);
        }
        #tbl-models-btn:hover { opacity: .85; }
        #tbl-models-panel {
            position: fixed; z-index: 200; background: var(--surface);
            border: 1px solid var(--border); border-radius: 8px;
            padding: .5rem; display: none; flex-direction: column; gap: .25rem;
            box-shadow: 0 8px 24px rgba(0,0,0,.12); min-width: 200px;
        }
        #tbl-models-panel.open { display: flex; }
        .tbl-model-row {
            display: flex; align-items: center; gap: .5rem; padding: .3rem .4rem;
            border-radius: 5px; cursor: pointer; font-size: .78rem; color: var(--navy);
        }
        .tbl-model-row:hover { background: #f1f5f9; }
        .tbl-model-row input { cursor: pointer; accent-color: var(--accent); }
        .tbl-model-sub { font-size: .65rem; color: var(--muted); margin-left: auto; }

        #tbl-status { font-size: .7rem; color: var(--muted); margin-left: auto; white-space: nowrap; }

        /* ── Table ── */
        #drawer-body { flex: 1; overflow: hidden; min-height: 0; }
        .wx-table-wrap {
            overflow-x: auto; overflow-y: hidden;
            height: 100%;
            scroll-behavior: auto; /* JS controls smooth/instant */
            cursor: grab;
            user-select: none;
            -webkit-user-select: none;
        }
        .wx-table-wrap * {
            user-select: none;
            -webkit-user-select: none;
        }
        .wx-table-wrap.is-dragging {
            cursor: grabbing;
            scroll-behavior: auto;
        }
        /* Always-visible thin scrollbar so user knows it scrolls */
        .wx-table-wrap::-webkit-scrollbar { height: 5px; width: 5px; }
        .wx-table-wrap::-webkit-scrollbar-track { background: #e2e8f0; }
        .wx-table-wrap::-webkit-scrollbar-thumb { background: #94a3b8; border-radius: 3px; }
        .wx-empty-state {
            padding: 2rem 1.5rem; text-align: center;
            color: var(--muted); font-size: .85rem;
        }
        .wx-wind-table {
            border-collapse: separate; border-spacing: 0;
            min-width: max(700px, 100%); width: max-content; font-size: .78rem;
        }
        .wx-wind-table thead th {
            position: sticky; top: 0; z-index: 10;
            background: var(--bg); border-bottom: 2px solid var(--border);
            padding: .35rem .2rem; color: var(--muted); font-weight: 600;
            text-align: center; white-space: pre; line-height: 1.2;
        }
        .wx-wind-table thead th.wx-time-col {
            cursor: pointer;
        }
        .wx-wind-table thead th.wx-time-col:hover {
            background: #e2e8f0; color: var(--navy);
        }
        .wx-wind-table thead th.wx-model-col {
            text-align: left; padding-left: .9rem; min-width: 180px;
            position: sticky; top: 0; left: 0; z-index: 20;
            background: var(--bg); border-right: 1px solid var(--border);
        }
        .wx-wind-table thead th.wx-day-break {
            border-left: 2px solid #94a3b8;
            color: #1B3A5C;
        }
        .wx-wind-table tbody td.wx-day-break {
            border-left: 2px solid #94a3b8;
        }
        .wx-wind-table thead th.wx-col-now {
            background: rgba(37,99,235,.08); outline: 2px solid #2563EB;
            outline-offset: -2px; color: #2563EB;
        }
        .wx-wind-table tbody td {
            border-bottom: 1px solid var(--border);
            border-right: 1px solid rgba(180,190,210,.2);
            padding: 0; text-align: center; height: 56px; width: 66px; min-width: 66px;
        }
        .wx-wind-table tbody td.wx-model-cell {
            position: sticky; left: 0; z-index: 5;
            background: var(--surface); text-align: left;
            padding: .35rem .9rem; border-right: 1px solid var(--border);
            min-width: 180px; max-width: 180px; overflow: hidden;
        }
        .wx-wind-table tbody td.wx-col-now { outline: 2px solid rgba(37,99,235,.35); outline-offset: -2px; }
        .wx-model-name { font-weight: 700; font-size: .78rem; color: var(--navy); line-height: 1.3;
                         white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .wx-model-sub  { font-size: .63rem; color: var(--muted); font-weight: 400; margin-left: .25rem; }
        .wx-model-run  { font-size: .6rem; color: #94a3b8; margin-top: .18rem; font-family: monospace;
                         white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .wx-cell {
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            height: 100%; padding: .15rem; gap: .03rem; cursor: default;
        }
        .wx-tws   { font-size: 1rem; font-weight: 800; font-variant-numeric: tabular-nums; line-height: 1.1; }
        .wx-arrow { font-size: .85rem; line-height: 1; display: inline-block; }
        .wx-gust  { font-size: .62rem; font-weight: 600; opacity: .85; }
        .wx-cape-val  { font-size: 1rem; font-weight: 800; }
        .wx-cape-tier { font-size: .62rem; }
        .wx-null  { color: rgba(0,0,0,.25); font-size: .72rem; }

        /* ── Hide Mapbox attribution clutter ── */
        .mapboxgl-ctrl-logo { display: none !important; }
        .mapboxgl-ctrl-attrib { display: none !important; }

        /* ── Pin coords: hidden (shown in comp table status bar) ── */
        #pin-coords { display: none; }

        /* ── Drawer toggle pill — lives inside model-pill-box ── */
        #drawer-fab {
            background: transparent; color: rgba(255,255,255,.75); border: 1px solid rgba(255,255,255,.25);
            padding: 3px 10px; border-radius: 12px; font-size: .68rem; font-weight: 600;
            cursor: pointer; display: flex; align-items: center; gap: 5px;
            font-family: var(--font); transition: background .15s, color .15s;
            width: 100%; justify-content: center; margin-top: 4px;
        }
        #drawer-fab:hover { background: rgba(255,255,255,.15); color: #fff; }
        #drawer-fab.fab-open { background: rgba(37,99,235,.35); color: #fff; border-color: rgba(37,99,235,.6); }
    </style>
</head>
<body>

    <!-- ── Header ── -->
    <header class="sd-header">
        <div style="display:flex;align-items:center;gap:.65rem;">
            <div class="sd-logo">Sail<span>Desk</span></div>
            <nav class="sd-tab-bar">
                <button class="sd-tab active" onclick="location.href='/weather'">Weather</button>
                <button class="sd-tab"        onclick="location.href='/'">Wind Map</button>
                <button class="sd-tab"        data-tab="briefing">Briefing</button>
                <button class="sd-tab"        data-tab="seabreeze">Sea Breeze</button>
                <button class="sd-tab"        data-tab="tactics">Tactics</button>
                <button class="sd-tab"        data-tab="course">Course</button>
            </nav>
        </div>
        <div class="sd-header-time" id="header-time"></div>
    </header>

    <div id="app">

        <!-- ── Map ── -->
        <div id="map-container">
            <div id="map"></div>
            <canvas id="particle-canvas"></canvas>
            <div id="loading-indicator">Connecting to Marine Matrix...</div>
            <div id="pin-coords">Drop pin on map for forecast</div>

            <!-- Map model pill box -->
            <div id="model-pill-box">
                <div id="source-toggle-zone">
                    <button id="src-api"  class="source-btn active" onclick="switchDataSource('api')">Cloud API</button>
                    <button id="src-grib" class="source-btn"        onclick="switchDataSource('grib')">Local GRIB</button>
                </div>
                <button class="model-pill active" id="pill-ecmwf_ifs" onclick="switchActiveForecastModel('ecmwf_ifs')" onmouseenter="hoverPrewarm('ecmwf_ifs')">
                    <span>ECMWF</span><span class="model-res-tag">9km</span>
                    <span class="grib-missing-label">No GRIB</span><span class="grib-dot" id="dot-ecmwf_ifs"></span>
                </button>
                <button class="model-pill" id="pill-meteofrance_arome_france_hd" onclick="switchActiveForecastModel('meteofrance_arome_france_hd')" onmouseenter="hoverPrewarm('meteofrance_arome_france_hd')">
                    <span>AROME HD</span><span class="model-res-tag">1.5km</span>
                    <span class="grib-missing-label">No GRIB</span><span class="grib-dot" id="dot-meteofrance_arome_france_hd"></span>
                </button>
                <button class="model-pill" id="pill-lamma_1k" onclick="switchActiveForecastModel('lamma_1k')" onmouseenter="hoverPrewarm('lamma_1k')">
                    <span>LaMMA</span><span class="model-res-tag">1km</span>
                    <span class="grib-missing-label">No GRIB</span><span class="grib-dot" id="dot-lamma_1k"></span>
                </button>
                <button class="model-pill" id="pill-icon_eu" onclick="switchActiveForecastModel('icon_eu')" onmouseenter="hoverPrewarm('icon_eu')">
                    <span>ICON</span><span class="model-res-tag">7km</span>
                    <span class="grib-missing-label">No GRIB</span><span class="grib-dot" id="dot-icon_eu"></span>
                </button>
                <button class="model-pill" id="pill-meteofrance_arpege_europe" onclick="switchActiveForecastModel('meteofrance_arpege_europe')" onmouseenter="hoverPrewarm('meteofrance_arpege_europe')">
                    <span>ARPEGE</span><span class="model-res-tag">11km</span>
                    <span class="grib-missing-label">No GRIB</span><span class="grib-dot" id="dot-meteofrance_arpege_europe"></span>
                </button>
                <!-- API-only wind model (hidden in GRIB mode) -->
                <button class="model-pill" id="pill-gfs_global" onclick="switchActiveForecastModel('gfs_global')" onmouseenter="hoverPrewarm('gfs_global')">
                    <span>GFS</span><span class="model-res-tag">22km</span>
                    <span class="grib-dot" id="dot-gfs_global"></span>
                </button>
                <!-- GRIB-only wave models (hidden in API mode) -->
                <button class="model-pill" id="pill-mfwam_arome" onclick="switchActiveForecastModel('mfwam_arome')" onmouseenter="hoverPrewarm('mfwam_arome')" style="display:none">
                    <span>Wave AROME</span><span class="model-res-tag">0.025°</span>
                    <span class="grib-missing-label">No GRIB</span><span class="grib-dot" id="dot-mfwam_arome"></span>
                </button>
                <button class="model-pill" id="pill-mfwam_ecmwf" onclick="switchActiveForecastModel('mfwam_ecmwf')" onmouseenter="hoverPrewarm('mfwam_ecmwf')" style="display:none">
                    <span>Wave ECMWF</span><span class="model-res-tag">0.2°</span>
                    <span class="grib-missing-label">No GRIB</span><span class="grib-dot" id="dot-mfwam_ecmwf"></span>
                </button>
                <!-- Compare models toggle — separate from map model picker -->
                <button id="drawer-fab" onclick="toggleDrawer()">
                    <span id="drawer-fab-icon">▲</span> Compare Models
                </button>
            </div>

            <!-- Pin popup (Windy-style) -->
            <div id="pin-popup">
                <div class="pp-label">Wind</div>
                <div class="pp-reading">
                    <span class="pp-speed" id="pp-speed">–</span>
                    <span class="pp-unit">kt</span>
