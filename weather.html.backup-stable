    const clientRenderedModels=new Set();

    function applyDot(modelId,state){
        const dot=document.getElementById(`dot-${modelId}`),pill=document.getElementById(`pill-${modelId}`);
        if(!dot||!pill) return;
        const ml=pill.querySelector('.grib-missing-label');
        dot.style.background='';dot.style.boxShadow='';
        if(state==='none'){dot.style.display='none';if(ml) ml.style.display='none';}
        else if(state==='missing'){dot.style.display='none';if(ml) ml.style.display='inline';}
        else if(state==='loading'){dot.className='grib-dot';dot.style.background='#f59e0b';dot.style.boxShadow='0 0 5px rgba(245,158,11,.7)';dot.style.display='block';if(ml) ml.style.display='none';}
        else if(state==='loaded'){dot.className='grib-dot green';dot.style.display='block';if(ml) ml.style.display='none';}
        else if(state==='error'){dot.className='grib-dot red';dot.style.display='block';if(ml) ml.style.display='none';}
    }
    function setModelDot(modelId,state){if(state==='loaded') clientRenderedModels.add(`${modelId}_${activeSourceId}`);applyDot(modelId,state);}
    function isRendered(modelId){return clientRenderedModels.has(`${modelId}_${activeSourceId}`);}
    function initAllDotsRed(){ALL_MAP_MODEL_IDS.forEach(id=>{const p=document.getElementById(`pill-${id}`);if(p&&p.style.display!=='none') applyDot(id,'error');});}
    async function refreshAllDots(){
        try{
            // Single endpoint covers both GRIB and API models
            const r=await fetch(`${API_BASE}/api/models/loaded`);
            const {loaded}=await r.json();
            const loadedSet=new Set(loaded);

            if(activeSourceId==='grib'){
                // Also fetch GRIB-specific status for 'missing' vs 'loading' distinction
                try{const gr=await fetch(`${API_BASE}/api/weather/grib-status`);const s=await gr.json();
                    for(const[id,info] of Object.entries(s)){
                        if(info.status==='missing') applyDot(id,'missing');
                        else if(info.loaded||loadedSet.has(`${id}_grib`)) applyDot(id,'loaded');
                        else applyDot(id,'loading');
                    }
                }catch(e){}
            } else {
                // API source: green if server has it loaded OR browser already rendered it
                ALL_MAP_MODEL_IDS.forEach(id=>{
                    const p=document.getElementById(`pill-${id}`);if(!p||p.style.display==='none') return;
                    if(loadedSet.has(`${id}_api`)||isRendered(id)) applyDot(id,'loaded');
                    else applyDot(id,'loading'); // orange while server still fetching
                });
            }
        }catch(e){}
    }

