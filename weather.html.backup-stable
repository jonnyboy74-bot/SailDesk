    }

    async function fetchTableData(){
        if(!selectedTableModels.size) return;
        document.getElementById('tbl-status').textContent='Fetching…';
        try {
            const models=[...selectedTableModels];
            const src = tableSource; // 'api' or 'grib'
            const isGrib = src==='grib';
            tableData={};
            const fetchedAt = new Date();

            if(isGrib){
                // GRIB mode: all models from local GRIB cache
                let anyGribLoading = false;
                await Promise.all(models.map(async id=>{
                    try{
                        const r=await fetch(`${API_BASE}/api/weather/point?lat=${pinLat}&lon=${pinLon}&model=${id}&source=grib`);
                        if(r.status===503){ anyGribLoading=true; return; }
                        const res=await r.json();
                        if(res.error||!res.data||!res.data.length) return;
                        const info=TABLE_GRIB_MODELS.find(m=>m.id===id);
                        tableData[id]={label:info?.label||id,res:info?.res||'',source:'GRIB',fetchedAt,
                            model_type:res.model_type||'wind',run_time:res.run_time||null,
                            timestamps:res.data.map(d=>d.timestamp),tws:res.data.map(d=>d.tws),
                            twd:res.data.map(d=>d.twd),gust:res.data.map(d=>d.gust),cape:res.data.map(d=>d.cape)};
                    }catch(e){ console.warn(`GRIB point fetch failed for ${id}:`, e); }
                }));
                if(anyGribLoading) scheduleTableRefresh(8000);
            } else {
                // API mode:
                // • Wind models  → local in-memory grid cache (/api/weather/point?source=api) — instant
                // • Wave models  → OM Marine API (/api/marine/om) — external but wave grids not cached locally
                const waveIds = models.filter(id=>TABLE_OM_WAVE_MODELS.some(m=>m.id===id));
                const windIds = models.filter(id=>!waveIds.includes(id));

                if(tableMetric==='cape'){
                    // CAPE isn't in the local grid cache — use OM point API for CAPE metric
                    try{
                        const resp=await fetch(`${API_BASE}/api/weather/om`,{
                            method:'POST',headers:{'Content-Type':'application/json'},
                            body:JSON.stringify({lat:pinLat,lon:pinLon,models:windIds})
                        });
                        if(!resp.ok) throw new Error(`HTTP ${resp.status}`);
                        const data=await resp.json();
                        for(const[id,res] of Object.entries(data)){
                            if(res.error||!res.data||!res.data.length) continue;
                            const info=TABLE_OM_MODELS.find(m=>m.id===id);
                            tableData[id]={label:info?.label||id,res:info?.res||'',source:'API',fetchedAt,
                                model_type:'wind',run_time:res.run_time||null,
                                timestamps:res.data.map(d=>d.timestamp),tws:res.data.map(d=>d.tws),
                                twd:res.data.map(d=>d.twd),gust:res.data.map(d=>d.gust),cape:res.data.map(d=>d.cape)};
                        }
                    }catch(e){ console.warn('OM CAPE fetch failed:', e); }
                } else {
                    // Wind mode: local in-memory grid cache (instant, no external call)
                    let anyStillLoading = false;
                    await Promise.all(windIds.map(async id=>{
                        try{
                            const r=await fetch(`${API_BASE}/api/weather/point?lat=${pinLat}&lon=${pinLon}&model=${id}&source=api`);
                            if(r.status===503){ anyStillLoading=true; return; } // model not ready yet
                            const res=await r.json();
                            if(res.error||!res.data||!res.data.length) return;
                            const info=TABLE_OM_MODELS.find(m=>m.id===id);
                            tableData[id]={label:info?.label||id,res:info?.res||'',source:'API',fetchedAt,
                                model_type:'wind',run_time:res.run_time||null,
                                timestamps:res.data.map(d=>d.timestamp),tws:res.data.map(d=>d.tws),
                                twd:res.data.map(d=>d.twd),gust:res.data.map(d=>d.gust),cape:res.data.map(d=>d.cape)};
                        }catch(e){ console.warn(`API point fetch failed for ${id}:`, e); }
                    }));
                    // Some models were still loading — retry in 8s to pick them up once ready
                    if(anyStillLoading) scheduleTableRefresh(8000);
                }

                // Waves: external Marine API
                if(waveIds.length){
                    try{
                        const resp=await fetch(`${API_BASE}/api/marine/om`,{
                            method:'POST',headers:{'Content-Type':'application/json'},
                            body:JSON.stringify({lat:pinLat,lon:pinLon,models:waveIds})
                        });
                        if(!resp.ok) throw new Error(`HTTP ${resp.status}`);
                        const data=await resp.json();
                        for(const[id,res] of Object.entries(data)){
                            if(res.error||!res.data||!res.data.length) continue;
                            const info=TABLE_OM_WAVE_MODELS.find(m=>m.id===id);
                            tableData[id]={label:info?.label||id,res:info?.res||'',source:'OM',fetchedAt,
                                model_type:'wave',run_time:res.run_time||null,
                                timestamps:res.data.map(d=>d.timestamp),tws:res.data.map(d=>d.tws),
                                twd:res.data.map(d=>d.twd),gust:res.data.map(d=>d.gust),cape:res.data.map(d=>d.cape)};
                        }
                    }catch(e){ console.warn('Marine wave fetch failed:', e); }
                }
            }

            renderTable();
            updateTableHighlight(true);
            const srcLabel = isGrib ? 'Local GRIB' : 'Cloud API';
            const displayed = Object.keys(tableData).filter(id=>selectedTableModels.has(id)).length;
            document.getElementById('tbl-status').textContent=`${srcLabel} • ${displayed} models • ${pinLat.toFixed(3)}°, ${pinLon.toFixed(3)}°`;
        } catch(e){
            console.error('fetchTableData error:', e);
            document.getElementById('tbl-status').textContent=`Fetch failed: ${e.message||e}`;
        }
    }

    // ═══════════════════════════════════════════════════════════
    // TABLE COLUMNS  (filtered by Race / 24HR)
    // ═══════════════════════════════════════════════════════════
    function getTableColumns(){
        // Use the model with the most timestamps so short-forecast models don't cut the table
        const first=Object.values(tableData).reduce((best,m)=>
            (m.timestamps&&m.timestamps.length>(best?.timestamps?.length||0)?m:best), null);
        if(!first||!first.timestamps||!first.timestamps.length) return [];
        const all=first.timestamps.map((ts,i)=>({ts,i}));

        if(tableHoursMode==='race'){
            const daysSet = new Set();
            return all.filter(({ts})=>{
                const d = new Date(ts.endsWith('Z')?ts:ts+'Z');
                const h = cestHour(d);
                if(h < 9 || h > 18) return false;
                // Track unique race days (date in Rome TZ)
                const dayKey = d.toLocaleString('sv',{timeZone:'Europe/Rome'}).split(' ')[0];
                daysSet.add(dayKey);
                return daysSet.size <= 5; // max 5 race days
            });
        }

        if(tableHoursMode==='24hr'){
            // Next 24 hours from start of data
            return all.slice(0,24);
        }

        // Full run — all available timestamps
        return all;
    }

    function cestHour(d){
        // Use Swedish locale: gives reliable "YYYY-MM-DD HH:MM:SS" format in all browsers
        const str = d.toLocaleString('sv', {timeZone:'Europe/Rome'});
        return parseInt(str.split(' ')[1].split(':')[0]);
    }
    function cestHHMM(d){
        const str = d.toLocaleString('sv', {timeZone:'Europe/Rome'});
        const parts = str.split(' ')[1].split(':');
        return `${parts[0]}:${parts[1]}`;
    }

    let _lastColDay = null;

    function formatColHeader(ts){
        const d=new Date(ts.endsWith('Z')?ts:ts+'Z');
        const hStr=cestHHMM(d);
        const day=new Intl.DateTimeFormat('en-US',{timeZone:'Europe/Rome',weekday:'short'}).format(d);

        if(tableHoursMode==='race'){
            // Show day name on first column of each new day
            if(day !== _lastColDay){
                _lastColDay = day;
                return `${day}\n${hStr}`;
            }
            return hStr;
        }

        const h=cestHour(d);
        if(h===0) return `${day}\n${hStr}`;
        return hStr;
    }

    // Find which table column index corresponds to the current map time slider
    function currentSliderColumnIndex(columns){
        if(!columns.length||!timelineTimestamps.length) return -1;
        const sliderTs=timelineTimestamps[currentFrameIdx];
        if(!sliderTs) return -1;
        const sliderTime=new Date(sliderTs.endsWith('Z')?sliderTs:sliderTs+'Z').getTime();
        let best=-1,bestDiff=Infinity;
        columns.forEach(({ts},ci)=>{
            const t=new Date(ts.endsWith('Z')?ts:ts+'Z').getTime();
            const diff=Math.abs(t-sliderTime);
            if(diff<bestDiff){bestDiff=diff;best=ci;}
        });
        return best;
    }

    let _lastHighlightCol = -1;

    async function jumpToTableColumn(ts, th){
        // Find the closest frame in the map timeline for this timestamp
        const targetTime = new Date(ts.endsWith('Z')?ts:ts+'Z').getTime();
        let bestIdx = 0, bestDiff = Infinity;
        timelineTimestamps.forEach((s,i)=>{
            const t = new Date(s.endsWith('Z')?s:s+'Z').getTime();
            const diff = Math.abs(t - targetTime);
            if(diff < bestDiff){ bestDiff=diff; bestIdx=i; }
        });

        // Jump the slider and map to that frame
        currentFrameIdx = bestIdx;
        document.getElementById('time-slider').value = bestIdx;
        updateTimeDisplay(true); // updates label + centres the column
        await streamIsolatedFrame(bestIdx);
        renderCurrentFrameToCanvas();
        updatePinPopup();
    }

    function updateTableHighlight(instant=false){
        const wrap = document.getElementById('wx-table-wrap');
        const table = wrap && wrap.querySelector('.wx-wind-table');
        if(!table) return;

        const cols = getTableColumns();
        const nowCol = currentSliderColumnIndex(cols);

        // Apply highlight classes
        const ths = table.querySelectorAll('thead th');
        let highlightedTh = null;
        ths.forEach((th, i) => {
            if(i === 0) return;
            const active = i - 1 === nowCol;
            th.classList.toggle('wx-col-now', active);
            if(active) highlightedTh = th;
        });
        table.querySelectorAll('tbody tr').forEach(tr => {
            Array.from(tr.cells).forEach((td, i) => {
                if(i === 0) return;
                td.classList.toggle('wx-col-now', i - 1 === nowCol);
            });
        });

        // Keep highlighted column centred in the visible area
        if(highlightedTh){
            _lastHighlightCol = nowCol;
            const allThs = Array.from(table.querySelectorAll('thead th'));
            let leftPos = 0;
            for(let i = 0; i < allThs.length; i++){
                if(allThs[i] === highlightedTh) break;
                leftPos += allThs[i].offsetWidth;
            }
            const colW = highlightedTh.offsetWidth || 66;
            const target = leftPos - wrap.clientWidth / 2 + colW / 2;
            wrap.scrollTo({ left: Math.max(0, target), behavior: instant ? 'instant' : 'smooth' });
        }
    }

    // ═══════════════════════════════════════════════════════════
    // RENDER TABLE
    // ═══════════════════════════════════════════════════════════
    function renderTable(){
        const wrap=document.getElementById('wx-table-wrap');
        const cols=getTableColumns();
        // Only render models that are currently selected (supports instant deselect/resize)
        const ids=Object.keys(tableData).filter(id=>selectedTableModels.has(id));
        if(!ids.length){
            wrap.innerHTML='<div class="wx-empty-state">Place a pin on the map then click <strong>Fetch Data</strong></div>';return;
        }
        const nowCol=currentSliderColumnIndex(cols);

        // Pre-compute headers (stateful day tracker runs once)
        _lastColDay = null;
        const headers = cols.map(({ts}) => formatColHeader(ts));
        const dayBreaks = headers.map(h => h.includes('\n'));

        const tbl=document.createElement('table');tbl.className='wx-wind-table';
        const thead=tbl.createTHead(),hr=thead.insertRow();
        const th0=document.createElement('th');th0.className='wx-model-col';th0.textContent='Model';hr.appendChild(th0);
        cols.forEach(({ts},ci)=>{
            const th=document.createElement('th');
            th.textContent=headers[ci];
            th.classList.add('wx-time-col');
            if(dayBreaks[ci]) th.classList.add('wx-day-break');
            if(ci===nowCol) th.classList.add('wx-col-now');
            th.addEventListener('click',()=>{ if(!_tableDragOccurred) jumpToTableColumn(ts, th); });
            hr.appendChild(th);
        });
        const tbody=tbl.createTBody();
        ids.forEach(id=>{
            const d=tableData[id],tr=tbody.insertRow();
            const ltd=document.createElement('td');ltd.className='wx-model-cell';
            // Line 2: run time + fetched time
            let line2Parts = [];
            if(d.run_time){
                // run_time is ISO "2026-06-12T06:00" — extract HH:MM in CEST
                try {
                    const rt = new Date(d.run_time.endsWith('Z')?d.run_time:d.run_time+'Z');
                    const hhmm = rt.toLocaleString('sv',{timeZone:'Europe/Rome'}).split(' ')[1].slice(0,5);
                    line2Parts.push(`run ${hhmm}`);
                } catch(e){}
            }
            if(d.fetchedAt){
                const hhmm = d.fetchedAt.toLocaleString('sv',{timeZone:'Europe/Rome'}).split(' ')[1].slice(0,5);
                line2Parts.push(`fetched ${hhmm}`);
            }
            const line2Html = line2Parts.length ? `<div class="wx-model-run">${line2Parts.join('  ')}</div>` : '';
            ltd.innerHTML=`<div class="wx-model-name">${d.label} <span class="wx-model-sub">${d.source} · ${d.res}</span></div>${line2Html}`;
            tr.appendChild(ltd);
            cols.forEach(({ts:cts,i:di},ci)=>{
                const td=document.createElement('td');
                if(ci===nowCol) td.classList.add('wx-col-now');
                if(dayBreaks[ci]) td.classList.add('wx-day-break');
                td.style.cursor='pointer';
                td.addEventListener('click', ()=>{
                    if(_tableDragOccurred) return;
                    jumpToTableColumn(cts, document.querySelectorAll('#wx-table-wrap thead th')[ci+1]);
                });
                if(d.model_type==='wave') renderWaveCell(td,d.tws?.[di],d.twd?.[di],d.gust?.[di]);
                else if(tableMetric==='wind') renderWindCell(td,d.tws?.[di],d.twd?.[di],d.gust?.[di]);
                else renderCapeCell(td,d.cape?.[di]);
                tr.appendChild(td);
            });
            tbody.appendChild(tr);
        });
        wrap.innerHTML='';wrap.appendChild(tbl);

        // Dynamically size drawer to exactly fit content — no vertical scroll
        const TOOLBAR_H = 46, THEAD_H = 38, ROW_H = 56, SCROLLBAR_H = 8, PAD = 4;
        const needed = TOOLBAR_H + THEAD_H + ids.length * ROW_H + SCROLLBAR_H + PAD;
        document.documentElement.style.setProperty('--drawer-h', needed + 'px');
    }

    function waveColor(hs) {
        if (hs == null) return "#f8fafc";
        for (let i = 1; i < WAVE_STOPS.length; i++) {
            const [s0,c0]=WAVE_STOPS[i-1],[s1,c1]=WAVE_STOPS[i];
            if (hs <= s1) return lerpHex(c0,c1,(hs-s0)/(s1-s0));
        }
        return WAVE_STOPS[WAVE_STOPS.length-1][1];
    }

    function renderWaveCell(td, hs, dir, period) {
        const bg = waveColor(hs), fg = contrastColor(bg);
        td.style.background = bg;
        const cell = document.createElement('div'); cell.className = 'wx-cell'; cell.style.color = fg;
        if (hs == null) {
            cell.innerHTML = '<span class="wx-null">—</span>';
        } else {
            const arrow = dir != null
                ? `<span class="wx-arrow" style="transform:rotate(${(dir+180)%360}deg);display:inline-block">↑</span>`
                : '<span class="wx-null">–</span>';
            const perStr = period != null ? `${period.toFixed(1)}s` : '—';
            cell.innerHTML = `<div class="wx-tws">${hs.toFixed(1)}</div>${arrow}<div class="wx-gust">${perStr}</div>`;
        }
        td.appendChild(cell);
    }

    function renderWindCell(td,tws,twd,gust){
        const bg=windColor(tws),fg=contrastColor(bg);
        td.style.background=bg;
        const cell=document.createElement('div');cell.className='wx-cell';cell.style.color=fg;
        if(tws==null){cell.innerHTML='<span class="wx-null">—</span>';}
        else{
            const arrow=twd!=null?`<span class="wx-arrow" style="transform:rotate(${(twd+180)%360}deg);display:inline-block">↑</span>`:'<span class="wx-null">–</span>';
            const gustVal = gust != null ? Math.round(gust) : null;
            const gustEst = gustVal == null && tws != null ? Math.round(tws * 1.25) : null;
            const gustStr = gustVal != null ? `G${gustVal}` : gustEst != null ? `~${gustEst}` : '—';
            cell.innerHTML=`<div class="wx-tws">${Math.round(tws)}</div>${arrow}<div class="wx-gust">${gustStr}</div>`;
        }
        td.appendChild(cell);
    }

    function renderCapeCell(td,cape){
        td.style.background=capeColor(cape);
        const cell=document.createElement('div');cell.className='wx-cell';
        cell.innerHTML=cape==null?'<span class="wx-null">—</span>':`<div class="wx-cape-val">${Math.round(cape)}</div><div class="wx-cape-tier">${capeTier(cape)}</div>`;
        td.appendChild(cell);
    }

    // ═══════════════════════════════════════════════════════════
    // DRAWER
    // ═══════════════════════════════════════════════════════════
    function toggleDrawer(){
        drawerOpen=!drawerOpen;
        const dr=document.getElementById('comparison-drawer');
        dr.classList.toggle('open',drawerOpen);
        const fab=document.getElementById('drawer-fab');
        document.getElementById('drawer-fab-icon').textContent=drawerOpen?'▼':'▲';
        fab.classList.toggle('fab-open',drawerOpen);
        setTimeout(()=>{resizeParticleCanvas();map.resize();},320);
        if(drawerOpen&&!Object.keys(tableData).length) fetchTableData();
    }

    // ═══════════════════════════════════════════════════════════
    // MODEL PICKER PANEL
    // ═══════════════════════════════════════════════════════════
    function rebuildModelPanel(){
        const panel=document.getElementById('tbl-models-panel');
        const isGrib = tableSource==='grib';
        const models = isGrib ? TABLE_GRIB_MODELS : TABLE_OM_MODELS;
        panel.innerHTML='';

        // Group: wind models first, then wave models
        const windModels = models.filter(m=>!WAVE_MODELS.has(m.id));
        const waveModels = models.filter(m=>WAVE_MODELS.has(m.id));

        function addRow({id,label,res}){
            const row=document.createElement('label');row.className='tbl-model-row';
            const cb=document.createElement('input');cb.type='checkbox';cb.value=id;
            cb.checked=selectedTableModels.has(id);
            cb.addEventListener('change',()=>{
                if(cb.checked){
                    selectedTableModels.add(id);
                    updateModelsBtnLabel();
                    scheduleTableRefresh(300); // fetch data for the newly added model
                } else {
                    selectedTableModels.delete(id);
                    updateModelsBtnLabel();
                    renderTable();
                    updateTableHighlight(true);
                    // Update status count and let map fill the reclaimed space
                    const srcLabel = tableSource==='grib'?'Local GRIB':'Cloud API';
                    const displayed = Object.keys(tableData).filter(x=>selectedTableModels.has(x)).length;
                    document.getElementById('tbl-status').textContent=`${srcLabel} • ${displayed} models • ${pinLat.toFixed(3)}°, ${pinLon.toFixed(3)}°`;
                    setTimeout(()=>{resizeParticleCanvas();map.resize();},20);
                }
            });
            const name=document.createElement('span');name.textContent=label;
            const sub=document.createElement('span');sub.className='tbl-model-sub';sub.textContent=res;
            row.appendChild(cb);row.appendChild(name);row.appendChild(sub);
            panel.appendChild(row);
        }

        windModels.forEach(addRow);

        if(isGrib && waveModels.length){
            const sep=document.createElement('div');sep.className='tbl-panel-sep';sep.textContent='── Wave (GRIB) ──';
            panel.appendChild(sep);
            waveModels.forEach(addRow);
        } else if(!isGrib){
            const sep=document.createElement('div');sep.className='tbl-panel-sep';sep.textContent='── Wave (OM Marine) ──';
            panel.appendChild(sep);
            TABLE_OM_WAVE_MODELS.forEach(addRow);
        }

        updateModelsBtnLabel();
    }
    function updateModelsBtnLabel(){document.getElementById('tbl-models-label').textContent=`${selectedTableModels.size} selected`;}

    function toggleModelPanel(e){
        e.stopPropagation();
        const panel=document.getElementById('tbl-models-panel');
        const open=panel.classList.toggle('open');
        if(open){
            const r=document.getElementById('tbl-models-btn').getBoundingClientRect();
            // Make temporarily visible at off-screen to measure height
            panel.style.visibility='hidden'; panel.style.display='flex';
            const ph=panel.offsetHeight;
            panel.style.visibility=''; panel.style.display='';
            const spaceBelow=window.innerHeight - r.bottom - 8;
            const spaceAbove=r.top - 8;
            if(spaceBelow >= ph || spaceBelow >= spaceAbove){
                panel.style.top=`${r.bottom+4}px`;
            } else {
                panel.style.top=`${r.top - ph - 4}px`;
            }
            panel.style.left=`${Math.min(r.left, window.innerWidth - panel.offsetWidth - 8)}px`;
        }
    }
    document.addEventListener('click',(e)=>{
        const panel=document.getElementById('tbl-models-panel');
        const btn=document.getElementById('tbl-models-btn');
        if(!panel.contains(e.target)&&!btn.contains(e.target)) panel.classList.remove('open');
    });

    // ═══════════════════════════════════════════════════════════
    // DRAG-TO-SCROLL TABLE
    // ═══════════════════════════════════════════════════════════
    // Set on the wrap so renderTable cells can read it
    let _tableDragOccurred = false;

    function initTableDragScroll(){
        const wrap = document.getElementById('wx-table-wrap');
        let isDragging = false, startX, startY, scrollLeft, scrollTop;

        wrap.addEventListener('mousedown', e => {
            if(e.target.closest('input')) return;
            e.preventDefault(); // stops text selection on drag
            isDragging = true;
            _tableDragOccurred = false;
            wrap.classList.add('is-dragging');
            startX = e.pageX - wrap.offsetLeft;
            startY = e.pageY - wrap.offsetTop;
            scrollLeft = wrap.scrollLeft;
            scrollTop  = wrap.scrollTop;
        });

        const stopDrag = () => { isDragging = false; wrap.classList.remove('is-dragging'); };
        wrap.addEventListener('mouseleave', stopDrag);
        wrap.addEventListener('mouseup',   stopDrag);

        wrap.addEventListener('mousemove', e => {
            if(!isDragging) return;
            e.preventDefault();
            const x = e.pageX - wrap.offsetLeft;
            const y = e.pageY - wrap.offsetTop;
            const dx = x - startX, dy = y - startY;
            if(Math.abs(dx) > 4 || Math.abs(dy) > 4) _tableDragOccurred = true;
            wrap.scrollLeft = scrollLeft - dx * 1.4;
            wrap.scrollTop  = scrollTop  - dy * 1.4;
        });

        // Touch support
        let touchStartX, touchStartY, touchScrollLeft, touchScrollTop;
        wrap.addEventListener('touchstart', e => {
            touchStartX     = e.touches[0].pageX;
            touchStartY     = e.touches[0].pageY;
            touchScrollLeft = wrap.scrollLeft;
            touchScrollTop  = wrap.scrollTop;
            _tableDragOccurred = false;
        }, {passive: true});
        wrap.addEventListener('touchmove', e => {
            const dx = touchStartX - e.touches[0].pageX;
            const dy = touchStartY - e.touches[0].pageY;
            if(Math.abs(dx) > 4 || Math.abs(dy) > 4) _tableDragOccurred = true;
            wrap.scrollLeft = touchScrollLeft + dx;
            wrap.scrollTop  = touchScrollTop  + dy;
        }, {passive: true});
    }

    // ═══════════════════════════════════════════════════════════
    // CLOCK
    // ═══════════════════════════════════════════════════════════
    function updateClock(){
        const el=document.getElementById('header-time');if(!el) return;
        const s=new Intl.DateTimeFormat('en-GB',{timeZone:'Europe/Rome',hour:'2-digit',minute:'2-digit',second:'2-digit',hour12:false}).format(new Date());
        el.textContent=`${s} CEST`;
    }
    updateClock();setInterval(updateClock,1000);

    // Auto-refresh all model dots every 10s — turns API and GRIB dots green as server loads them
    setInterval(refreshAllDots, 10000);

    // ═══════════════════════════════════════════════════════════
    // INIT
    // ═══════════════════════════════════════════════════════════
        map.on('error', e => console.error('Mapbox error:', e));

        map.on('load',()=>{
        resizeParticleCanvas();
        window.addEventListener('resize',()=>{resizeParticleCanvas();map.resize();});
        map.on('move',()=>{pCtx.clearRect(0,0,pCanvas.width,pCanvas.height);});

        document.getElementById('time-slider').addEventListener('input',async e=>{
            if(isPlaying){clearTimeout(playTimer);isPlaying=false;document.getElementById('play-btn').textContent='▶';}
            currentFrameIdx=parseInt(e.target.value);
            updateTimeDisplay(true);  // instant scroll — single call, no duplicate
            await streamIsolatedFrame(currentFrameIdx);
            if(currentFrameIdx===parseInt(e.target.value)){
                renderCurrentFrameToCanvas();
                updatePinPopup();
            }
        });

        initPin();
        initTableDragScroll();
        rebuildModelPanel();
        applySourceVisibility();
        initAllDotsRed();
        executeSlicedModelSync().then(()=>{
            initParticlePool();runningParticleLoop();refreshAllDots();
            updatePinPopup();
            // Auto-populate the comparison table once the map is ready
            scheduleTableRefresh(1500);
        });
    });
    </script>
