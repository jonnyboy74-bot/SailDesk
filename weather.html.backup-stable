    // ═══════════════════════════════════════════════════════════
    // COLOR HELPERS
    // ═══════════════════════════════════════════════════════════
    const colorScale = [
        { knots: 0,  color: [49,59,96,0]   },
        { knots: 4,  color: [54,87,150,255] },
        { knots: 10, color: [64,143,160,255]},
