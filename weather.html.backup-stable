    async function executeSlicedModelSync(){
        const _syncModel  = activeModelId;
        const _syncSource = activeSourceId;
        // Only flash dot orange if we don't already have a cached frame for this model
        const _hasCached  = !!browserSideFrameMatrixCache[`${_syncModel}_${_syncSource}_frame_${currentFrameIdx}`];
        if(!_hasCached) setModelDot(_syncModel,'loading');
        const li=document.getElementById('loading-indicator');
        li.style.display='block'; li.style.color='#fff';
        try {
            const r=await fetch(`${API_BASE}/api/weather/metadata?model=${_syncModel}&source=${_syncSource}`);
            const d=await r.json();
            if(d.loading){
                // Still loading in background — show message, schedule retry, do NOT touch dot
                li.style.color='#f59e0b';
                li.innerText=_syncSource==='grib'?'GRIB loading… retrying in 12s':'API loading…';
                // Retry only if user hasn't switched to a different model/source
                setTimeout(()=>{
                    if(activeModelId===_syncModel && activeSourceId===_syncSource) executeSlicedModelSync();
                }, 12000);
                return;
            }
            if(d.error) throw new Error(d.error);
            const ph=d.header; timelineTimestamps=d.timestamps;
            const sl=document.getElementById('time-slider');
            sl.max=timelineTimestamps.length-1;
            currentFrameIdx=findClosestTimeIndex(timelineTimestamps);sl.value=currentFrameIdx;
            const pf=await streamIsolatedFramePending(currentFrameIdx);
            metadataHeader=ph;currentActiveFrameData=pf;
            updateTimeDisplay();buildTimeAxis();
            initWeatherCanvas();await renderCurrentFrameToCanvas();mountOrUpdateWeatherLayer();
            // Guard: if user switched away while we were loading, don't overwrite their state
            if(activeModelId!==_syncModel || activeSourceId!==_syncSource) return;
            li.style.display='none';
            setModelDot(_syncModel,'loaded');
            syncScaleBar();
            triggerBackgroundCacheWarmup();
        } catch(e){
            if(activeModelId===_syncModel && activeSourceId===_syncSource){
                li.style.color='#ff3333';
                li.innerText='No data — try another model';
                setModelDot(_syncModel,'error');
            }
        }
    }

    // Decode a binary frame response into {uData, vData, gustData} 2-D arrays
    async function _fetchFrameBinary(model, source, idx){
        const r = await fetch(`${API_BASE}/api/weather/frame.bin?model=${model}&source=${source}&frame=${idx}`);
        if(!r.ok) throw new Error(`HTTP ${r.status}`);
        const buf  = await r.arrayBuffer();
        const i32  = new Int32Array(buf, 0, 2);
        const ny   = i32[0], nx = i32[1];
        const n    = ny * nx;
        const base = 8; // 2 × int32 = 8 bytes
        const uFlat = new Float32Array(buf, base,           n);
        const vFlat = new Float32Array(buf, base + n*4,     n);
        const gFlat = new Float32Array(buf, base + n*4*2,   n);
        // Reshape flat arrays into 2-D arrays (rows = lat, cols = lon)
        const uData=[], vData=[], gustData=[];
        for(let r2=0;r2<ny;r2++){
            uData.push(Array.from(uFlat.subarray(r2*nx,(r2+1)*nx)));
            vData.push(Array.from(vFlat.subarray(r2*nx,(r2+1)*nx)));
            gustData.push(Array.from(gFlat.subarray(r2*nx,(r2+1)*nx)));
        }
        return {uData, vData, gustData};
    }

    async function streamIsolatedFramePending(idx){
        const k=`${activeModelId}_${activeSourceId}_frame_${idx}`;
        if(browserSideFrameMatrixCache[k]) return browserSideFrameMatrixCache[k];
        const d=await _fetchFrameBinary(activeModelId,activeSourceId,idx);
        browserSideFrameMatrixCache[k]=d; return d;
    }
    async function streamIsolatedFrame(idx){
        updateTimeDisplay();
        const k=`${activeModelId}_${activeSourceId}_frame_${idx}`;
        if(browserSideFrameMatrixCache[k]){currentActiveFrameData=browserSideFrameMatrixCache[k];return;}
        const d=await _fetchFrameBinary(activeModelId,activeSourceId,idx);
        browserSideFrameMatrixCache[k]=d; currentActiveFrameData=d;
    }
    async function triggerBackgroundCacheWarmup(){
        const m=activeModelId,s=activeSourceId;
        for(let f=0;f<timelineTimestamps.length;f++){
            if(m!==activeModelId||s!==activeSourceId) break;
            const k=`${m}_${s}_frame_${f}`;
            if(!browserSideFrameMatrixCache[k]){
                try{const d=await _fetchFrameBinary(m,s,f);
                    browserSideFrameMatrixCache[k]=d;await new Promise(res=>setTimeout(res,40));}catch(e){}
            }
        }
    }

