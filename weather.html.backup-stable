    // ═══════════════════════════════════════════════════════════
    function updateTimeDisplay(instant=false){
        if(!timelineTimestamps||!timelineTimestamps[currentFrameIdx]) return;
        let s=timelineTimestamps[currentFrameIdx];
        if(s&&!s.endsWith("Z")&&!s.includes("+")) s+="Z";
        const d=new Date(s);
        document.getElementById('time-display-text').textContent=isNaN(d)?`Step ${currentFrameIdx}`:d.toLocaleString('en-US',{timeZone:'Europe/Rome',weekday:'short',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit',hour12:false})+' CEST';
        updateTableHighlight(instant);
    }

    function buildTimeAxis(){
        const ax=document.getElementById('time-axis');
        if(!timelineTimestamps||timelineTimestamps.length<2){ax.innerHTML='';return;}
        ax.innerHTML='';
        const total=timelineTimestamps.length-1;
        // Pick tick interval: every 6h if <=5 days, else every 12h
        const spanHours=total; // each step is ~1h
        const stepH = spanHours <= 120 ? 6 : 12;

        timelineTimestamps.forEach((s,i)=>{
            let ts=s; if(ts&&!ts.endsWith('Z')&&!ts.includes('+')) ts+='Z';
            const d=new Date(ts);
            const h=cestHour(d);
            const romStr=d.toLocaleString('sv',{timeZone:'Europe/Rome'});
            const m=parseInt(romStr.split(' ')[1].split(':')[1]);
            if(m!==0) return;             // only on the hour
            if(h % stepH !== 0) return;   // only every stepH hours

            const pct=(i/total)*100;
            const span=document.createElement('span');
            span.className='ta-tick'+(h===0?' ta-day':'');
            span.style.left=pct+'%';
            span.textContent = h===0
                ? d.toLocaleString('en-US',{timeZone:'Europe/Rome',weekday:'short'})
                : String(h).padStart(2,'0');
            ax.appendChild(span);
        });
    }

