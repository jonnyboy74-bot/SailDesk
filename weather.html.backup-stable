    function getWindColorContinuous(speed) {
        if (WAVE_MODELS.has(activeModelId)) {
            // speed here is SWH in m/s equivalent — but for waves u/v encodes swh directly as m
            const swh = speed; // swh in metres
            const sc = WAVE_COLOR_SCALE;
            if (swh <= sc[0].m) return sc[0].color;
            if (swh >= sc[sc.length-1].m) return sc[sc.length-1].color;
            for (let i = 0; i < sc.length-1; i++) {
                const lo=sc[i], hi=sc[i+1];
                if (swh >= lo.m && swh <= hi.m) {
                    const t=(swh-lo.m)/(hi.m-lo.m);
                    return [lo.color[0]+t*(hi.color[0]-lo.color[0]),lo.color[1]+t*(hi.color[1]-lo.color[1]),
                            lo.color[2]+t*(hi.color[2]-lo.color[2]),lo.color[3]+t*(hi.color[3]-lo.color[3])];
                }
            }
            return [0,0,0,0];
        }
        const knots = speed * 1.94384;
        if (knots <= colorScale[0].knots) return colorScale[0].color;
        if (knots >= colorScale[colorScale.length-1].knots) return colorScale[colorScale.length-1].color;
        for (let i = 0; i < colorScale.length-1; i++) {
            const lo = colorScale[i], hi = colorScale[i+1];
            if (knots >= lo.knots && knots <= hi.knots) {
                const t = (knots - lo.knots) / (hi.knots - lo.knots);
                return [lo.color[0]+t*(hi.color[0]-lo.color[0]), lo.color[1]+t*(hi.color[1]-lo.color[1]),
                        lo.color[2]+t*(hi.color[2]-lo.color[2]), lo.color[3]+t*(hi.color[3]-lo.color[3])];
            }
        }
        return [0,0,0,0];
    }

    function lerpHex(c0,c1,t) {
        const r0=parseInt(c0.slice(1,3),16),g0=parseInt(c0.slice(3,5),16),b0=parseInt(c0.slice(5,7),16);
        const r1=parseInt(c1.slice(1,3),16),g1=parseInt(c1.slice(3,5),16),b1=parseInt(c1.slice(5,7),16);
        const r=Math.round(r0+(r1-r0)*t),g=Math.round(g0+(g1-g0)*t),b=Math.round(b0+(b1-b0)*t);
        return `#${r.toString(16).padStart(2,"0")}${g.toString(16).padStart(2,"0")}${b.toString(16).padStart(2,"0")}`;
    }
    function windColor(tws) {
        if (tws == null) return "#f8fafc";
        if (tws <= 0) return WIND_STOPS[0][1];
        for (let i = 1; i < WIND_STOPS.length; i++) {
            const [s0,c0]=WIND_STOPS[i-1],[s1,c1]=WIND_STOPS[i];
            if (tws <= s1) return lerpHex(c0,c1,(tws-s0)/(s1-s0));
        }
        return WIND_STOPS[WIND_STOPS.length-1][1];
    }
    function contrastColor(hex) {
        const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);
        return (0.299*r+0.587*g+0.114*b) > 140 ? "#1B3A5C" : "#ffffff";
    }
    function capeColor(cape) {
        if (cape==null||cape<100) return "#eef9f3";
        if (cape<500) return "#fff6df";
        return "#fff0f0";
    }
    function capeTier(cape) {
        if (cape==null) return "–";
        if (cape<100) return "low";
        if (cape<500) return "mod";
        return "HIGH";
    }

    // ═══════════════════════════════════════════════════════════
    // MAP WIND LAYER
    // ═══════════════════════════════════════════════════════════
    function findClosestTimeIndex(timestamps) {
        if (!timestamps||!timestamps.length) return 0;
        const now = new Date(); let idx=0,min=Infinity;
        for (let i=0;i<timestamps.length;i++) {
            let s=timestamps[i];
            if (s&&!s.endsWith("Z")&&!s.includes("+")) s+="Z";
            const d=Math.abs(now-new Date(s));
            if (d<min){min=d;idx=i;}
        }
        return idx;
    }

    function getInterpolatedWind(lng,lat) {
        if (!metadataHeader||!currentActiveFrameData) return {u:0,v:0,speed:0};
        const h=metadataHeader;
        const maxLng=h.lo1+(h.dx*(h.nx-1)), minLat=h.la1-(h.dy*(h.ny-1));
        if (lat>h.la1||lat<minLat||lng<h.lo1||lng>maxLng) return {u:0,v:0,speed:0};
        let x=(lng-h.lo1)/h.dx, y=(h.la1-lat)/h.dy;
        let x0=Math.floor(x),x1=Math.min(x0+1,h.nx-1),y0=Math.floor(y),y1=Math.min(y0+1,h.ny-1);
        let xt=x-x0,yt=y-y0;
        x0=Math.max(0,Math.min(x0,h.nx-1));x1=Math.max(0,Math.min(x1,h.nx-1));
        y0=Math.max(0,Math.min(y0,h.ny-1));y1=Math.max(0,Math.min(y1,h.ny-1));
        const u=((1-yt)*((1-xt)*(currentActiveFrameData.uData?.[y0]?.[x0]??0)+xt*(currentActiveFrameData.uData?.[y0]?.[x1]??0))
                +yt*((1-xt)*(currentActiveFrameData.uData?.[y1]?.[x0]??0)+xt*(currentActiveFrameData.uData?.[y1]?.[x1]??0)));
        const v=((1-yt)*((1-xt)*(currentActiveFrameData.vData?.[y0]?.[x0]??0)+xt*(currentActiveFrameData.vData?.[y0]?.[x1]??0))
                +yt*((1-xt)*(currentActiveFrameData.vData?.[y1]?.[x0]??0)+xt*(currentActiveFrameData.vData?.[y1]?.[x1]??0)));
        return {u,v,speed:Math.sqrt(u*u+v*v)};
    }

    function latToMercY(lat){return Math.log(Math.tan(Math.PI/4+(lat*Math.PI/180)/2));}
    function mercYToLat(y){return (2*Math.atan(Math.exp(y))-Math.PI/2)*180/Math.PI;}

    function renderCurrentFrameToCanvas() {
        return new Promise(resolve => {
            if (!metadataHeader||!currentActiveFrameData||!weatherCanvas){resolve();return;}
            if (isRenderingFrame){resolve();return;}
            isRenderingFrame=true;
            setTimeout(()=>{
                if (!metadataHeader||!currentActiveFrameData?.uData){isRenderingFrame=false;resolve();return;}
                try {
                    const h=metadataHeader, tw=weatherCanvas.width, th=weatherCanvas.height;
                    const totalLng=h.dx*(h.nx-1), botLat=h.la1-h.dy*(h.ny-1);
                    const mTop=latToMercY(h.la1), mBot=latToMercY(botLat);
                    let p=0;
                    for (let y=0;y<th;y++) {
                        const lat=mercYToLat(mTop-(y/(th-1))*(mTop-mBot));
                        for (let x=0;x<tw;x++) {
                            const lng=h.lo1+(x/(tw-1))*totalLng;
                            const c=getWindColorContinuous(getInterpolatedWind(lng,lat).speed);
                            weatherImgData.data[p]=Math.round(c[0]);weatherImgData.data[p+1]=Math.round(c[1]);
                            weatherImgData.data[p+2]=Math.round(c[2]);weatherImgData.data[p+3]=Math.round(c[3]);p+=4;
                        }
                    }
                    weatherCtx.clearRect(0,0,tw,th);weatherCtx.putImageData(weatherImgData,0,0);map.triggerRepaint();
                } catch(e){} finally {isRenderingFrame=false;resolve();}
            },0);
        });
    }

    function resizeParticleCanvas(){const c=document.getElementById('map-container');pCanvas.width=c.offsetWidth;pCanvas.height=c.offsetHeight;}
    function initParticlePool(){particles=[];for(let i=0;i<maxParticles;i++)particles.push({x:Math.random()*pCanvas.width,y:Math.random()*pCanvas.height,age:Math.floor(Math.random()*55)});}

    function runningParticleLoop(){
        if(!pCtx) return; requestAnimationFrame(runningParticleLoop);
        if(!metadataHeader||!currentActiveFrameData?.uData||!particles.length){pCtx.clearRect(0,0,pCanvas.width,pCanvas.height);return;}
        pCtx.globalCompositeOperation='destination-in';pCtx.fillStyle='rgba(0,0,0,0.90)';pCtx.fillRect(0,0,pCanvas.width,pCanvas.height);
        pCtx.globalCompositeOperation='source-over';pCtx.strokeStyle='rgba(255,255,255,0.75)';pCtx.lineWidth=2.2;
        const z=map.getZoom(),vs=0.075/Math.sqrt(z-3||1),vc=Math.min(maxParticles,Math.round(maxParticles*(6/z)));
        for(let i=0;i<vc;i++){
            let p=particles[i]; if(!p) continue;
            if(isNaN(p.x)||p.x<0||p.x>pCanvas.width||p.y<0||p.y>pCanvas.height){p.x=Math.random()*pCanvas.width;p.y=Math.random()*pCanvas.height;p.age=0;continue;}
            let ll; try{ll=map.unproject([p.x,p.y]);}catch(e){p.x=Math.random()*pCanvas.width;p.y=Math.random()*pCanvas.height;p.age=0;continue;}
            const w=getInterpolatedWind(ll.lng,ll.lat); let u=w.u,v=w.v,sk=w.speed*1.94384;
            if(sk<4&&sk>0.1){const b=4/sk;u*=b;v*=b;}
            if(w.speed<=0.1||p.age>65){p.x=Math.random()*pCanvas.width;p.y=Math.random()*pCanvas.height;p.age=0;continue;}
            const nx=p.x+(u*vs*3.6),ny=p.y-(v*vs*3.6);
            if(!isNaN(nx)&&!isNaN(ny)){pCtx.beginPath();pCtx.moveTo(p.x,p.y);pCtx.lineTo(nx,ny);pCtx.stroke();}
            p.x=nx;p.y=ny;p.age++;
        }
    }

    function applyMarineThemeOverlays(labelLayerId,coastlineId){
        const style=map.getStyle();if(!style||!style.layers) return;
        for(const layer of style.layers){
            if(layer.id.includes('landcover')||layer.id.includes('national_park')||layer.id.includes('road')) map.setLayoutProperty(layer.id,'visibility','none');
            if(layer.id==='background'||layer.id.includes('land')||layer.id.includes('landuse')){
                if(layer.type==='background') map.setPaintProperty(layer.id,'background-color','rgba(74,91,107,0.78)');
                if(layer.type==='fill') map.setPaintProperty(layer.id,'fill-color','rgba(74,91,107,0.78)');
            }
            if(layer.type==='symbol'){try{map.setPaintProperty(layer.id,'text-color','#ffffff');map.setPaintProperty(layer.id,'text-halo-color','rgba(15,23,42,0.95)');map.setPaintProperty(layer.id,'text-halo-width',1.8);}catch(e){}}
        }
        if(!map.getLayer(coastlineId)) map.addLayer({id:coastlineId,type:'line',source:'composite','source-layer':'water',paint:{'line-color':'#11151c','line-width':1.2,'line-opacity':0.95}},labelLayerId);
    }

    const WX_CANVAS_ID='weather-canvas-main',WX_SOURCE_ID='weather-source-main',WX_LAYER_ID='weather-layer-main',WX_COAST_ID='crisp-coastlines-main';

    function initWeatherCanvas(){
        let c=document.getElementById(WX_CANVAS_ID);
        if(!c){c=document.createElement('canvas');c.id=WX_CANVAS_ID;c.width=1600;c.height=1000;c.style.display='none';document.body.appendChild(c);}
        weatherCanvas=c;weatherCtx=weatherCanvas.getContext('2d',{willReadFrequently:true});weatherImgData=weatherCtx.createImageData(weatherCanvas.width,weatherCanvas.height);
    }

    function mountOrUpdateWeatherLayer(){
        if(!metadataHeader) return;
        const h=metadataHeader;
        const coords=[[h.lo1,h.la1],[h.lo1+h.dx*(h.nx-1),h.la1],[h.lo1+h.dx*(h.nx-1),h.la1-h.dy*(h.ny-1)],[h.lo1,h.la1-h.dy*(h.ny-1)]];
        if(map.getSource(WX_SOURCE_ID)){map.getSource(WX_SOURCE_ID).setCoordinates(coords);}
        else{
            const layers=map.getStyle().layers;let lbl;
            for(let i=0;i<layers.length;i++){if(layers[i].type==='symbol'){lbl=layers[i].id;break;}}
            map.addSource(WX_SOURCE_ID,{type:'canvas',canvas:WX_CANVAS_ID,animate:true,coordinates:coords});
            map.addLayer({id:WX_LAYER_ID,type:'raster',source:WX_SOURCE_ID,paint:{'raster-opacity':0.88,'raster-resampling':'linear'}},lbl);
            applyMarineThemeOverlays(lbl,WX_COAST_ID);
        }
        const src=map.getSource(WX_SOURCE_ID);if(src) src.play();map.triggerRepaint();
    }

